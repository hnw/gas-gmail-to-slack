{
  "name": "gas-gmail-to-slack",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clasp:login": "clasp login",
    "clasp:create": "clasp create --title gmail-to-slack --type sheets --rootDir ./dist",
    "clasp:push": "pnpm build && clasp push",
    "clasp:pull": "clasp pull",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json}": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@google/clasp": "^3.2.0",
    "@types/google-apps-script": "^2.0.8",
    "esbuild": "^0.27.3",
    "esbuild-gas-plugin": "^0.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
